{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=bankinsight;Username=postgres;Password=postgres"
  },
  "JwtSettings": {
    "Secret": "bankinsight_dev_secret_must_be_at_least_32_characters_long_in_production_use_env_var",
    "Issuer": "BankInsight",
    "Audience": "BankInsightAPI",
    "ExpirationMinutes": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Debug"
    }
  },
  "Security": {
    "IpWhitelist": {
      "Enabled": true,
      "AllowedIps": [
        "127.0.0.1",
        "::1",
        "localhost"
      ]
    },
    "SuspiciousActivity": {
      "LargeTransactionThreshold": 100000
    }
  },
  "SmtpSettings": {
    "Enabled": false,
    "Host": "localhost",
    "Port": 1025,
    "EnableSsl": false,
    "Username": "",
    "Password": "",
    "FromAddress": "alerts@bankinsight.local",
    "Recipients": [
      "security@bankinsight.local",
      "admin@bankinsight.local"
    ],
    "TimeoutSeconds": 30
  }
}

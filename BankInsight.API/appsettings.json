{
  "ConnectionStrings": {
    "DefaultConnection": "${DB_CONNECTION_STRING}"
  },
  "JwtSettings": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "BankInsight",
    "Audience": "BankInsightAPI",
    "ExpirationMinutes": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Security": {
    "IpWhitelist": {
      "Enabled": false,
      "AllowedIps": []
    },
    "SuspiciousActivity": {
      "LargeTransactionThreshold": 100000
    }
  },
  "SmtpSettings": {
    "Enabled": false,
    "Host": "",
    "Port": 587,
    "EnableSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "alerts@bankinsight.local",
    "Recipients": [],
    "TimeoutSeconds": 30
  },
  "AllowedHosts": "*"
}